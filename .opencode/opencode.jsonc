{
  "$schema": "https://opencode.ai/config.json",
  // GitHub Actions runs are non-interactive: nobody can answer an "ask"
  // permission prompt (the built-in default for external_directory), so a
  // tool call that tries to read outside the checked-out repository (for
  // example inspecting /opt/pipx/logs/* after a failed tool install) hangs
  // until the action's timeout-minutes kills the run. /review-pr never
  // needs to read outside the repository it is reviewing, so deny instead
  // of ask by default: the agent gets an immediate, non-interactive denial
  // it can adapt to rather than a silent hang.
  //
  // One narrow exception: /review-pr sources the bundled App-token
  // resolver from "${HOME}/.config/opencode/scripts/resolve-app-token.sh"
  // (see .opencode/commands/review-pr.md), which the install step copies
  // outside the checked-out repository into ~/.config/opencode. Rules are
  // evaluated in order with the last match winning, so the catch-all deny
  // stays first and this single script path is allow-listed after it;
  // every other external path remains denied.
  "permission": {
    "external_directory": {
      "*": "deny",
      "$HOME/.config/opencode/scripts/resolve-app-token.sh": "allow"
    }
  }
}
